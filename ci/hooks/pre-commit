#!/usr/bin/env bash
# Pre-commit hook: mod-parse + secret + credential checks before a commit lands.
# Activated (with pre-push) via: git config core.hooksPath ci/hooks
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

echo "pre-commit: running checks ..."
if ! ./ci/checks.sh; then
  echo
  echo "pre-commit: checks failed — commit aborted."
  exit 1
fi
